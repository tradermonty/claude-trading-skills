# =============================================================================
# Environment Variables Template for Automated Trader
# =============================================================================
# Copy this file to `.env` (which is gitignored) and fill in your real keys.
#   cp config/.env.example .env
#   vim .env
#
# The repo's scripts/with_env.sh wrapper loads .env before running any script.
# =============================================================================

# -----------------------------------------------------------------------------
# Alpaca Trading API (PAPER TRADING ONLY until checklist signed)
# -----------------------------------------------------------------------------
# Sign up for free paper account: https://alpaca.markets/
# Paper keys start with "PK..." for key id and have a separate paper dashboard.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true                    # MUST be "true" until LIVE_TRADING_CHECKLIST.md is signed

# -----------------------------------------------------------------------------
# Financial Modeling Prep (FMP) - market data, fundamentals, earnings
# -----------------------------------------------------------------------------
# Sign up: https://site.financialmodelingprep.com/developer/docs
# Free tier: 250 calls/day
FMP_API_KEY=

# -----------------------------------------------------------------------------
# FRED (Federal Reserve Economic Data) - macro indicators
# -----------------------------------------------------------------------------
# Free. Sign up: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# -----------------------------------------------------------------------------
# FINVIZ Elite (optional) - enhanced screening
# -----------------------------------------------------------------------------
# $39.50/month subscription required. Skippable for most skills.
FINVIZ_API_KEY=

# -----------------------------------------------------------------------------
# Safety overrides - leave at defaults unless you know exactly what you're doing
# -----------------------------------------------------------------------------
# Master DRY_RUN switch - if true, NO orders are sent anywhere even in "live" mode
TRADE_LOOP_DRY_RUN=true

# Path to the signed LIVE_TRADING_CHECKLIST.md (required for live mode)
LIVE_TRADING_CHECKLIST_PATH=LIVE_TRADING_CHECKLIST.md
