<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  SETUP: Replace $HOME and $PROJECT_DIR before installing.
    sed "s|\$HOME|$HOME|g; s|\$PROJECT_DIR|$(pwd)|g" \
      launchd/com.trade-analysis.sod-capture.plist \
      > ~/Library/LaunchAgents/com.trade-analysis.sod-capture.plist
    launchctl load ~/Library/LaunchAgents/com.trade-analysis.sod-capture.plist

  Fires at 09:20 ET daily. Wrapper gates on Mon-Fri.
  launchd clocks follow the Mac's local TZ - if the Mac is not on ET, adjust
  Hour/Minute here accordingly.
-->
<dict>
	<key>Label</key>
	<string>com.trade-analysis.sod-capture</string>

	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>$PROJECT_DIR/scripts/run_sod_capture.sh</string>
	</array>

	<key>WorkingDirectory</key>
	<string>$PROJECT_DIR</string>

	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>9</integer>
		<key>Minute</key>
		<integer>20</integer>
	</dict>

	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/opt/homebrew/sbin:$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
		<key>HOME</key>
		<string>$HOME</string>
	</dict>

	<key>StandardOutPath</key>
	<string>$PROJECT_DIR/logs/launchd_sod_capture.log</string>

	<key>StandardErrorPath</key>
	<string>$PROJECT_DIR/logs/launchd_sod_capture_error.log</string>

	<key>RunAtLoad</key>
	<false/>
</dict>
</plist>
