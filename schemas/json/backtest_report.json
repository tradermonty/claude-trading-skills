{
  "$defs": {
    "DataGap": {
      "description": "A single data gap record \u2014 emitted when expected data is absent or stale.",
      "properties": {
        "gap_id": {
          "title": "Gap Id",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity"
        },
        "description": {
          "description": "What data is missing or stale",
          "title": "Description",
          "type": "string"
        },
        "affected_decision": {
          "description": "Which downstream decision this impairs",
          "title": "Affected Decision",
          "type": "string"
        },
        "remediation": {
          "description": "How the user can resolve this gap",
          "title": "Remediation",
          "type": "string"
        },
        "can_continue": {
          "description": "Whether the skill/workflow can produce useful output despite this gap",
          "title": "Can Continue",
          "type": "boolean"
        },
        "source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Which upstream skill or API caused the gap",
          "title": "Source"
        }
      },
      "required": [
        "severity",
        "description",
        "affected_decision",
        "remediation",
        "can_continue"
      ],
      "title": "DataGap",
      "type": "object"
    },
    "Disclaimer": {
      "properties": {
        "text": {
          "default": "This artifact is produced by TraderMonty, a decision-support and trading-process toolkit. It is NOT financial advice, investment advisory, a trading signal, or a guarantee of profitability. All trading decisions, position sizing, risk management, and broker execution decisions remain solely the user's responsibility. Review all outputs manually before acting.",
          "title": "Text",
          "type": "string"
        },
        "decision_support_only": {
          "default": true,
          "title": "Decision Support Only",
          "type": "boolean"
        }
      },
      "title": "Disclaimer",
      "type": "object"
    },
    "ManualReviewStatus": {
      "description": "Lifecycle state of the human review gate for an artifact.",
      "enum": [
        "PENDING",
        "IN_REVIEW",
        "APPROVED",
        "REJECTED",
        "WAIVED"
      ],
      "title": "ManualReviewStatus",
      "type": "string"
    },
    "ReviewerRole": {
      "description": "Role of the reviewer who completed or waived the review.",
      "enum": [
        "RESEARCHER",
        "REVIEWER",
        "RISK_APPROVER",
        "ADMIN"
      ],
      "title": "ReviewerRole",
      "type": "string"
    },
    "Severity": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ],
      "title": "Severity",
      "type": "string"
    }
  },
  "description": "Results of a completed backtest.\n\nA BacktestReport is ONLY valid if the accompanying BacktestSpec has:\n  - no_lookahead_confirmed = True\n  - survivorship_bias_acknowledged = True\n  - transaction_cost_bps is not None\n  - slippage_bps is not None\n  - out_of_sample_start is not None",
  "properties": {
    "schema_version": {
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_type": {
      "default": "backtest_report",
      "title": "Artifact Type",
      "type": "string"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "skill_id": {
      "description": "ID of the skill that produced this artifact",
      "title": "Skill Id",
      "type": "string"
    },
    "workflow_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Workflow run ID if produced within a workflow",
      "title": "Workflow Id"
    },
    "workflow_run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Workflow Run Id"
    },
    "symbols": {
      "description": "Tickers/assets covered",
      "items": {
        "type": "string"
      },
      "title": "Symbols",
      "type": "array"
    },
    "data_sources_used": {
      "description": "APIs, CSVs, or other sources consumed",
      "items": {
        "type": "string"
      },
      "title": "Data Sources Used",
      "type": "array"
    },
    "data_gaps": {
      "description": "All detected data gaps; empty list = no gaps detected",
      "items": {
        "$ref": "#/$defs/DataGap"
      },
      "title": "Data Gaps",
      "type": "array"
    },
    "assumptions": {
      "description": "Explicit assumptions made due to missing or inferred data",
      "items": {
        "type": "string"
      },
      "title": "Assumptions",
      "type": "array"
    },
    "confidence": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "HIGH / MEDIUM / LOW \u2014 reflects data completeness and signal quality",
      "title": "Confidence"
    },
    "manual_review_required": {
      "default": true,
      "title": "Manual Review Required",
      "type": "boolean"
    },
    "manual_review_status": {
      "$ref": "#/$defs/ManualReviewStatus",
      "default": "PENDING",
      "description": "Review lifecycle: PENDING \u2192 IN_REVIEW \u2192 APPROVED / REJECTED. WAIVED is permitted only for non-trade artifacts (e.g., data quality reports). Promotion-blocking: outputs with status PENDING or IN_REVIEW must not be acted upon."
    },
    "reviewer": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Name or identifier of the human reviewer who completed or waived the review",
      "title": "Reviewer"
    },
    "reviewed_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "ISO-8601 timestamp when the review was completed or waived",
      "title": "Reviewed At"
    },
    "review_notes": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Reviewer's notes, decision rationale, or conditions attached to the approval",
      "title": "Review Notes"
    },
    "reviewer_role": {
      "anyOf": [
        {
          "$ref": "#/$defs/ReviewerRole"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Role of the reviewer who completed or waived the review"
    },
    "author_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "ID of the artifact author; used to prevent self-review",
      "title": "Author Id"
    },
    "dual_review_required": {
      "default": false,
      "description": "Whether a second independent reviewer is required",
      "title": "Dual Review Required",
      "type": "boolean"
    },
    "secondary_reviewer": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Secondary Reviewer"
    },
    "secondary_reviewer_role": {
      "anyOf": [
        {
          "$ref": "#/$defs/ReviewerRole"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "secondary_reviewed_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Secondary Reviewed At"
    },
    "secondary_review_notes": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Secondary Review Notes"
    },
    "next_actions": {
      "description": "Suggested next steps for the user",
      "items": {
        "type": "string"
      },
      "title": "Next Actions",
      "type": "array"
    },
    "disclaimer": {
      "$ref": "#/$defs/Disclaimer"
    },
    "spec_artifact_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "artifact_id of the BacktestSpec used",
      "title": "Spec Artifact Id"
    },
    "strategy_name": {
      "title": "Strategy Name",
      "type": "string"
    },
    "total_trades": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Total Trades"
    },
    "win_rate_pct": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Win Rate Pct"
    },
    "avg_win_pct": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Avg Win Pct"
    },
    "avg_loss_pct": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Avg Loss Pct"
    },
    "profit_factor": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Profit Factor"
    },
    "max_drawdown_pct": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Max Drawdown Pct"
    },
    "sharpe_ratio": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sharpe Ratio"
    },
    "cagr_pct": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cagr Pct"
    },
    "in_sample_metrics": {
      "additionalProperties": true,
      "title": "In Sample Metrics",
      "type": "object"
    },
    "out_of_sample_metrics": {
      "additionalProperties": true,
      "title": "Out Of Sample Metrics",
      "type": "object"
    },
    "out_of_sample_degradation_pct": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "% degradation from in-sample to out-of-sample (positive = degraded)",
      "title": "Out Of Sample Degradation Pct"
    },
    "regime_breakdown": {
      "additionalProperties": true,
      "title": "Regime Breakdown",
      "type": "object"
    },
    "overfitting_warnings": {
      "items": {
        "type": "string"
      },
      "title": "Overfitting Warnings",
      "type": "array"
    },
    "false_discovery_risk": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "LOW / MEDIUM / HIGH \u2014 how many configs were tested",
      "title": "False Discovery Risk"
    },
    "validation_status": {
      "default": "UNVALIDATED",
      "description": "UNVALIDATED / IN_SAMPLE_ONLY / OUT_OF_SAMPLE_PASSED / OUT_OF_SAMPLE_FAILED",
      "title": "Validation Status",
      "type": "string"
    },
    "paper_trade_required": {
      "default": true,
      "description": "Paper trade required before live use",
      "title": "Paper Trade Required",
      "type": "boolean"
    }
  },
  "required": [
    "skill_id",
    "strategy_name"
  ],
  "title": "BacktestReport",
  "type": "object"
}
